# ===========================================
# Fleet Earnings Management System - Environment Configuration
# ===========================================

# ========== APPLICATION ==========
NODE_ENV=development
APP_NAME=Fleet Earnings Management System
APP_URL=http://localhost:5173
PORT=3000

# ========== DATABASE ==========
# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/database
# For local: postgresql://postgres:password@localhost:5432/fleet_db
# For production: Use your cloud database URL (Azure Database for PostgreSQL, etc.)
DATABASE_URL=postgresql://postgres:password@localhost:5432/fleet_db

# ========== JWT / AUTHENTICATION ==========
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345678
JWT_EXPIRY=7d

# ========== SECURITY ==========
# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Rate limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========== GEMINI AI (Optional) ==========
# Leave empty if not using AI features
GEMINI_API_KEY=

# ========== LOGGING ==========
LOG_LEVEL=info

# ========== SESSION ==========
SESSION_SECRET=your_session_secret_key_change_this_in_production_87654321
SESSION_TIMEOUT_MINUTES=60

# ========== EMAIL (Optional) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@fleetsystem.com

# ========== SENTRY / ERROR TRACKING (Optional) ==========
SENTRY_DSN=

# ========== FILE UPLOAD ==========
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=/uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# ========== FEATURES (Feature Flags) ==========
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_AUDIT_LOGS=true
ENABLE_TWO_FACTOR_AUTH=false
